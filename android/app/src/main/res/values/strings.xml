<resources>
    <string name="app_name">trck</string>

    <!-- Notification -->
    <string name="notification_channel_name">GPS Recording</string>
    <string name="notification_channel_desc">Ongoing notification while GPS is being recorded in the background.</string>
    <string name="notification_title">Запись GPS…</string>

    <!--
      Notification body text. Uses Russian plurals for the point count so the
      grammar is correct for 1 / 2-4 / 5-0 forms. The duration is always a
      pre-formatted mm:ss or h:mm:ss string (see formatDuration in
      GpsRecorderService.kt).
    -->
    <string name="notification_text">%1$s · %2$s</string>
    <string name="notification_text_paused">Запись приостановлена (остановка) · %1$s · %2$s</string>
    <string name="notification_text_signal_lost">Нет сигнала GPS · %1$s · %2$s</string>
    <string name="notification_action_stop">Стоп</string>

    <!-- Russian plural forms for "N points" (точка / точки / точек). -->
    <plurals name="notification_points">
        <item quantity="one">%d точка</item>
        <item quantity="few">%d точки</item>
        <item quantity="many">%d точек</item>
        <item quantity="other">%d точек</item>
    </plurals>
</resources>
